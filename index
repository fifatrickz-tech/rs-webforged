<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>RS WebForged — Premium Web Design Studio</title>
  <meta name="description" content="RS WebForged designs premium, conversion-focused websites for businesses that want stronger positioning, sharper identity, and more enquiries." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Syne:wght@700;800&display=swap" rel="stylesheet" />
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

  <style>
    :root {
      --bg:         #0a0a0f;
      --bg-2:       #0e0e15;
      --surface:    #13131c;
      --surface-2:  #1a1a26;
      --line:       rgba(255,255,255,0.07);
      --line-md:    rgba(255,255,255,0.12);
      --text:       #e8e8f0;
      --muted:      #7a7a96;
      --soft:       #b0b0c8;
      --accent:     #6c63ff;
      --accent-2:   #8b85ff;
      --accent-glow:rgba(108,99,255,0.22);
      --white:      #ffffff;
      --container:  1240px;
      --ease:       cubic-bezier(0.16, 1, 0.3, 1);
      --shadow-lg:  0 40px 100px rgba(0,0,0,0.6);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }

    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; }
    button, input, textarea, select { font: inherit; }

    /* ─── NOISE OVERLAY ─────────────────────────── */
    body::before {
      content: "";
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      background:
        radial-gradient(ellipse 70% 55% at 75% -5%, rgba(108,99,255,0.18) 0%, transparent 60%),
        radial-gradient(ellipse 50% 40% at 10% 90%, rgba(108,99,255,0.08) 0%, transparent 55%);
    }

    /* ─── UTILITY ───────────────────────────────── */
    .container {
      width: min(92%, var(--container));
      margin: 0 auto;
      position: relative;
      z-index: 1;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      color: var(--accent-2);
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      margin-bottom: 18px;
    }

    .eyebrow::before {
      content: "";
      display: block;
      width: 22px;
      height: 1px;
      background: var(--accent-2);
      flex-shrink: 0;
    }

    .lead {
      font-size: clamp(1rem, 1.35vw, 1.15rem);
      color: var(--muted);
      max-width: 58ch;
      line-height: 1.7;
    }

    /* ─── BUTTON ────────────────────────────────── */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 14px 26px;
      background: var(--accent);
      border: 1px solid var(--accent);
      color: var(--white);
      font-size: 0.82rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      border-radius: 6px;
      transition: all 0.3s var(--ease);
      position: relative;
      overflow: hidden;
      white-space: nowrap;
    }

    .btn::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(255,255,255,0.14), transparent);
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 32px rgba(108,99,255,0.38);
    }

    .btn:hover::after { opacity: 1; }

    .btn-ghost {
      background: transparent;
      border-color: var(--line-md);
      color: var(--soft);
    }

    .btn-ghost:hover {
      border-color: rgba(108,99,255,0.5);
      color: var(--white);
      box-shadow: 0 8px 24px rgba(0,0,0,0.22);
    }

    /* ─── NAV ───────────────────────────────────── */
    .site-header {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 1000;
      transition: background 0.4s ease, border-color 0.4s ease;
    }

    .site-header.scrolled {
      background: rgba(10,10,15,0.88);
      border-bottom: 1px solid var(--line);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
    }

    .nav-wrap {
      height: 72px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 14px;
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: 1.05rem;
      letter-spacing: -0.01em;
    }

    .brand-icon {
      width: 38px;
      height: 38px;
      border-radius: 8px;
      background: var(--accent);
      display: grid;
      place-items: center;
      font-size: 0.78rem;
      font-weight: 800;
      flex-shrink: 0;
      box-shadow: 0 4px 18px rgba(108,99,255,0.4);
    }

    .brand-name { color: var(--white); }
    .brand-name span { color: var(--accent-2); }

    .site-nav {
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .site-nav a {
      padding: 8px 14px;
      font-size: 0.86rem;
      color: var(--soft);
      border-radius: 6px;
      transition: color 0.2s ease, background 0.2s ease;
    }

    .site-nav a:hover {
      color: var(--white);
      background: rgba(255,255,255,0.05);
    }

    .nav-cta {
      margin-left: 10px;
    }

    /* ─── HAMBURGER (FIXED) ───────────────────── */
.nav-toggle {
  display: none;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 5px;
  width: 40px;
  height: 40px;
  background: transparent;
  border: 1px solid var(--line-md);
  border-radius: 6px;
  cursor: pointer;
  z-index: 3001;
}

.nav-toggle span {
  display: block;
  width: 18px;
  height: 2px;
  background: var(--white);
  border-radius: 2px;
  transition: 0.3s var(--ease);
}

/* animation fix */
.nav-toggle.active span:nth-child(1) {
  transform: translateY(7px) rotate(45deg);
}
.nav-toggle.active span:nth-child(2) {
  opacity: 0;
}
.nav-toggle.active span:nth-child(3) {
  transform: translateY(-7px) rotate(-45deg);
}

/* MOBILE NAV FIX */
@media (max-width: 900px) {
  .nav-toggle {
    display: flex;
  }

  .site-nav {
    position: fixed;
    top: 72px;
    left: 0;
    right: 0;
    bottom: 0;

    flex-direction: column;
    align-items: center;
    justify-content: center;

    background: rgba(10, 10, 15, 0.98);
    backdrop-filter: blur(25px);

    border-top: 1px solid var(--line);

    opacity: 0;
    transform: translateY(-10px);
    pointer-events: none;

    transition: 0.35s var(--ease);

    z-index: 3000;
  }

  .site-nav.open {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .site-nav a {
    font-size: 1.2rem;
    padding: 14px 30px;
    width: 100%;
    max-width: 320px;
    text-align: center;
  }
}

/* prevent scroll when menu open */
body.menu-open {
  overflow: hidden;
}

      .nav-cta {
        margin-left: 0;
        margin-top: 8px;
      }
    

    /* ─── HERO ──────────────────────────────────── */
    .hero {
      position: relative;
      min-height: 100svh;
      display: flex;
      align-items: center;
      padding-top: 72px;
      overflow: hidden;
    }

    .hero-grid-bg {
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(var(--line) 1px, transparent 1px),
        linear-gradient(90deg, var(--line) 1px, transparent 1px);
      background-size: 64px 64px;
      mask-image: radial-gradient(ellipse 80% 60% at 50% 40%, black 0%, transparent 70%);
      pointer-events: none;
    }

    .hero-inner {
      padding: clamp(80px, 10vw, 140px) 0;
      max-width: 860px;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 7px 14px;
      border: 1px solid rgba(108,99,255,0.35);
      background: rgba(108,99,255,0.1);
      border-radius: 100px;
      font-size: 0.76rem;
      font-weight: 500;
      color: var(--accent-2);
      letter-spacing: 0.04em;
      margin-bottom: 32px;
      opacity: 0;
      transform: translateY(12px);
      animation: fadeUp 0.7s var(--ease) 0.1s forwards;
    }

    .hero-badge::before {
      content: "";
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--accent-2);
      box-shadow: 0 0 8px var(--accent-2);
      flex-shrink: 0;
    }

    .hero h1 {
      font-family: 'Syne', sans-serif;
      font-size: clamp(3rem, 8vw, 7.2rem);
      font-weight: 800;
      line-height: 0.95;
      letter-spacing: -0.04em;
      color: var(--white);
      opacity: 0;
      transform: translateY(24px);
      animation: fadeUp 0.9s var(--ease) 0.2s forwards;
    }

    .hero h1 em {
      font-style: normal;
      color: transparent;
      -webkit-text-stroke: 1.5px rgba(255,255,255,0.3);
    }

    .hero-desc {
      margin-top: 28px;
      font-size: clamp(1rem, 1.4vw, 1.15rem);
      color: var(--muted);
      max-width: 52ch;
      line-height: 1.7;
      opacity: 0;
      transform: translateY(20px);
      animation: fadeUp 0.9s var(--ease) 0.35s forwards;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 36px;
      opacity: 0;
      transform: translateY(20px);
      animation: fadeUp 0.9s var(--ease) 0.5s forwards;
    }

    .hero-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 34px;
      margin-top: 60px;
      padding-top: 40px;
      border-top: 1px solid var(--line);
      opacity: 0;
      animation: fadeUp 0.9s var(--ease) 0.7s forwards;
    }

    .hero-meta-item strong {
      display: block;
      font-family: 'Syne', sans-serif;
      font-size: 1.6rem;
      font-weight: 700;
      color: var(--white);
      letter-spacing: -0.03em;
      
    }

    .hero-meta-item span {
      font-size: 0.82rem;
      color: var(--muted);
      margin-top: 2px;
      display: block;
    }

    @keyframes fadeUp {
      to { opacity: 1; transform: translateY(0); }
    }

    /* Scroll indicator */
    .scroll-hint {
      position: absolute;
      bottom: 5px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      color: var(--muted);
      font-size: 0.72rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      opacity: 0;
      animation: fadeUp 1s var(--ease) 1.1s forwards;
    }

    .scroll-hint::after {
      content: "";
      width: 1px;
      height: 40px;
      background: linear-gradient(to bottom, var(--muted), transparent);
      animation: scrollPulse 2s ease infinite;
    }

    @keyframes scrollPulse {
      0%, 100% { opacity: 0.4; }
      50% { opacity: 1; }
    }

    /* ─── MARQUEE ───────────────────────────────── */
    .marquee {
      overflow: hidden;
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
      padding: 16px 0;
      background: var(--surface);
    }

    .marquee-track {
      display: flex;
      width: max-content;
      gap: 0;
      animation: marquee 28s linear infinite;
    }

    .marquee-track:hover { animation-play-state: paused; }

    .marquee-item {
      display: flex;
      align-items: center;
      gap: 28px;
      padding: 0 28px;
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--soft);
      white-space: nowrap;
    }

    .marquee-item::after {
      content: "·";
      color: var(--accent-2);
      font-size: 1.2rem;
    }

    @keyframes marquee {
      from { transform: translateX(0); }
      to { transform: translateX(-50%); }
    }

    /* ─── SECTIONS ──────────────────────────────── */
    .section {
      padding: clamp(90px, 10vw, 140px) 0;
      position: relative;
    }

    .section + .section {
      border-top: 1px solid var(--line);
    }

    /* ─── VALUE CARDS ───────────────────────────── */
    .cards-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--line);
      border: 1px solid var(--line);
      border-radius: 12px;
      overflow: hidden;
    }

    .value-card {
      background: var(--surface);
      padding: clamp(28px, 3.5vw, 44px);
      transition: background 0.35s ease;
    }

    .value-card:hover {
      background: var(--surface-2);
    }

    .value-card-icon {
      width: 44px;
      height: 44px;
      border-radius: 10px;
      background: rgba(108,99,255,0.15);
      border: 1px solid rgba(108,99,255,0.3);
      display: grid;
      place-items: center;
      margin-bottom: 24px;
    }

    .value-card-icon svg { width: 20px; height: 20px; stroke: var(--accent-2); }

    .value-card h3 {
      font-family: 'Syne', sans-serif;
      font-size: 1.15rem;
      font-weight: 700;
      color: var(--white);
      margin-bottom: 10px;
      letter-spacing: -0.02em;
    }

    .value-card p {
      font-size: 0.92rem;
      color: var(--muted);
      line-height: 1.65;
    }

    /* ─── PROOF / PROBLEM ───────────────────────── */
    .split-layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(40px, 6vw, 90px);
      align-items: start;
    }

    .split-left h2 {
      font-family: 'Syne', sans-serif;
      font-size: clamp(2.2rem, 4.5vw, 4rem);
      font-weight: 800;
      color: var(--white);
      line-height: 1.05;
      letter-spacing: -0.04em;
    }

    .split-left h2 span {
      color: var(--accent-2);
    }

    .item-list {
      border-top: 1px solid var(--line);
      margin-top: 18px;
    }

    .item-list-row {
      display: flex;
      align-items: flex-start;
      gap: 18px;
      padding: 22px 0;
      border-bottom: 1px solid var(--line);
      transition: padding-left 0.3s var(--ease), border-color 0.3s ease;
      cursor: default;
    }

    .item-list-row:hover {
      padding-left: 10px;
      border-color: rgba(108,99,255,0.3);
    }

    .item-list-row:hover .row-dot { background: var(--accent-2); box-shadow: 0 0 10px var(--accent-2); }

    .row-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--surface-2);
      border: 1px solid var(--line-md);
      flex-shrink: 0;
      margin-top: 7px;
      transition: background 0.3s ease, box-shadow 0.3s ease;
    }

    .item-list-row strong {
      display: block;
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--white);
      margin-bottom: 4px;
      letter-spacing: -0.01em;
    }

    .item-list-row p {
      font-size: 0.88rem;
      color: var(--muted);
      margin: 0;
      line-height: 1.6;
    }

    /* ─── WORK ──────────────────────────────────── */
    .work-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 24px;
      margin-bottom: 48px;
    }

    .work-header h2 {
      font-family: 'Syne', sans-serif;
      font-size: clamp(2rem, 4vw, 3.5rem);
      font-weight: 800;
      color: var(--white);
      letter-spacing: -0.04em;
      line-height: 1;
    }

    .projects-scroll {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(min(100%, 540px), 1fr));
      gap: 24px;
    }

    .project-card {
      border-radius: 12px;
      overflow: hidden;
      border: 1px solid var(--line);
      background: var(--surface);
      transition: transform 0.5s var(--ease), box-shadow 0.5s ease, border-color 0.5s ease;
    }

    .project-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 28px 60px rgba(0,0,0,0.45);
      border-color: rgba(108,99,255,0.4);
    }

    .project-thumb {
      aspect-ratio: 16/10;
      overflow: hidden;
      position: relative;
      background: var(--surface-2);
    }

    .project-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.8s var(--ease), filter 0.8s ease;
    }

    .project-card:hover .project-thumb img {
      transform: scale(1.06);
      filter: brightness(0.6);
    }

    .project-thumb-overlay {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: flex-end;
      padding: 24px;
      background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, transparent 55%);
      opacity: 0;
      transition: opacity 0.5s ease;
    }

    .project-card:hover .project-thumb-overlay { opacity: 1; }

    .project-view-link {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 9px 16px;
      border-radius: 6px;
      background: var(--white);
      color: var(--bg);
      font-size: 0.8rem;
      font-weight: 600;
      transition: transform 0.25s ease;
    }

    .project-view-link:hover { transform: scale(1.04); }

    .project-body {
      padding: 24px 26px 26px;
    }

    .project-type-tag {
      display: inline-block;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent-2);
      margin-bottom: 8px;
    }

    .project-body h3 {
      font-family: 'Syne', sans-serif;
      font-size: 1.3rem;
      font-weight: 700;
      color: var(--white);
      letter-spacing: -0.02em;
      margin-bottom: 8px;
    }

    .project-body p {
      font-size: 0.88rem;
      color: var(--muted);
      line-height: 1.6;
      margin-bottom: 16px;
    }

    .tag-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .tag {
      padding: 5px 10px;
      border: 1px solid var(--line-md);
      border-radius: 4px;
      font-size: 0.74rem;
      color: var(--muted);
      letter-spacing: 0.04em;
    }

    /* ─── SERVICES ──────────────────────────────── */
    .services-list {
      border-top: 1px solid var(--line);
    }

    .service-row {
      display: grid;
      grid-template-columns: 260px 1fr auto;
      gap: 32px;
      align-items: center;
      padding: 36px 0;
      border-bottom: 1px solid var(--line);
      transition: padding-left 0.4s var(--ease);
      cursor: default;
    }

    .service-row:hover { padding-left: 16px; }

    .service-num {
      font-family: 'Syne', sans-serif;
      font-size: 0.78rem;
      font-weight: 700;
      color: var(--accent-2);
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .service-row h3 {
      font-family: 'Syne', sans-serif;
      font-size: clamp(1.4rem, 2.5vw, 2rem);
      font-weight: 700;
      color: var(--white);
      letter-spacing: -0.03em;
    }

    .service-row p {
      font-size: 0.9rem;
      color: var(--muted);
      margin-top: 6px;
      max-width: 56ch;
    }

    .service-arrow {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      border: 1px solid var(--line-md);
      display: grid;
      place-items: center;
      flex-shrink: 0;
      transition: background 0.3s ease, border-color 0.3s ease, transform 0.3s ease;
    }

    .service-row:hover .service-arrow {
      background: var(--accent);
      border-color: var(--accent);
      transform: rotate(45deg);
    }

    .service-arrow svg { width: 18px; height: 18px; stroke: var(--white); }

    /* ─── PROCESS ───────────────────────────────── */
    .process-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--line);
      border: 1px solid var(--line);
      border-radius: 12px;
      overflow: hidden;
    }

    .process-step {
      background: var(--surface);
      padding: clamp(28px, 3.5vw, 44px);
      display: flex;
      flex-direction: column;
      gap: 20px;
      transition: background 0.3s ease;
    }

    .process-step:hover { background: var(--surface-2); }

    .process-num {
      font-family: 'Syne', sans-serif;
      font-size: 2.8rem;
      font-weight: 800;
      color: rgba(108,99,255,0.25);
      line-height: 1;
      letter-spacing: -0.04em;
      transition: color 0.3s ease;
    }

    .process-step:hover .process-num { color: rgba(108,99,255,0.5); }

    .process-step h3 {
      font-family: 'Syne', sans-serif;
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--white);
      letter-spacing: -0.02em;
    }

    .process-step p {
      font-size: 0.9rem;
      color: var(--muted);
      line-height: 1.65;
      margin: 0;
    }

    /* ─── ABOUT ─────────────────────────────────── */
    .about-grid {
      display: grid;
      grid-template-columns: 0.9fr 1.1fr;
      gap: clamp(40px, 6vw, 90px);
      align-items: start;
    }

    .about-sticky {
      position: sticky;
      top: 100px;
    }

    .about-sticky h2 {
      font-family: 'Syne', sans-serif;
      font-size: clamp(2.2rem, 4vw, 3.5rem);
      font-weight: 800;
      color: var(--white);
      letter-spacing: -0.04em;
      line-height: 1.05;
      margin-bottom: 20px;
    }

    .about-facts {
      display: grid;
      gap: 0;
      border-top: 1px solid var(--line);
    }

    .about-fact {
      padding: 22px 0;
      border-bottom: 1px solid var(--line);
      display: grid;
      grid-template-columns: 130px 1fr;
      gap: 20px;
      align-items: start;
    }

    .about-fact-label {
      font-size: 0.76rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--muted);
      padding-top: 2px;
    }

    .about-fact p {
      font-size: 0.92rem;
      color: var(--soft);
      line-height: 1.65;
    }

    .about-values { display: grid; gap: 20px; }

    .about-value-block {
      padding: clamp(22px, 2.5vw, 32px);
      border: 1px solid var(--line);
      border-radius: 10px;
      background: var(--surface);
      transition: border-color 0.3s ease, background 0.3s ease;
    }

    .about-value-block:hover {
      border-color: rgba(108,99,255,0.35);
      background: var(--surface-2);
    }

    .about-value-block h3 {
      font-family: 'Syne', sans-serif;
      font-size: 1rem;
      font-weight: 700;
      color: var(--white);
      margin-bottom: 8px;
      letter-spacing: -0.01em;
    }

    .about-value-block p {
      font-size: 0.88rem;
      color: var(--muted);
      line-height: 1.6;
    }

    /* ─── PRICING ───────────────────────────────── */
    .pricing-header {
      text-align: center;
      margin-bottom: 56px;
    }

    .pricing-header h2 {
      font-family: 'Syne', sans-serif;
      font-size: clamp(2.4rem, 5vw, 4rem);
      font-weight: 800;
      color: var(--white);
      letter-spacing: -0.04em;
      line-height: 1;
      margin-bottom: 16px;
    }

    .pricing-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
      max-width: 860px;
      margin: 0 auto;
    }

    .price-card {
      padding: clamp(28px, 3.5vw, 44px);
      border: 1px solid var(--line);
      border-radius: 14px;
      background: var(--surface);
      display: flex;
      flex-direction: column;
      gap: 24px;
      transition: border-color 0.3s ease, box-shadow 0.3s ease;
    }

    .price-card:hover {
      border-color: rgba(108,99,255,0.35);
      box-shadow: 0 20px 50px rgba(0,0,0,0.3);
    }

    .price-card.featured {
      border-color: rgba(108,99,255,0.5);
      background: linear-gradient(135deg, rgba(108,99,255,0.12), var(--surface) 55%);
      position: relative;
    }

    .featured-badge {
      position: absolute;
      top: 20px;
      right: 20px;
      padding: 5px 12px;
      border-radius: 100px;
      background: var(--accent);
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      color: var(--white);
    }

    .price-plan-name {
      font-size: 0.76rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .price-card h3 {
      font-family: 'Syne', sans-serif;
      font-size: 1.3rem;
      font-weight: 700;
      color: var(--white);
      letter-spacing: -0.02em;
      margin-top: 4px;
    }

    .price-amount {
      font-family: 'Syne', sans-serif;
      font-size: clamp(2.8rem, 5vw, 3.8rem);
      font-weight: 800;
      color: var(--white);
      letter-spacing: -0.04em;
      line-height: 1;
    }

    .price-amount small {
      font-family: 'Inter', sans-serif;
      font-size: 0.88rem;
      font-weight: 400;
      color: var(--muted);
      letter-spacing: 0;
      display: block;
      margin-top: 6px;
    }

    .price-features {
      list-style: none;
      display: grid;
      gap: 12px;
    }

    .price-features li {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      font-size: 0.9rem;
      color: var(--soft);
    }

    .price-features li::before {
      content: "";
      width: 16px;
      height: 16px;
      border-radius: 50%;
      background: rgba(108,99,255,0.2);
      border: 1px solid rgba(108,99,255,0.4);
      flex-shrink: 0;
      margin-top: 2px;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 16 16' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M4 8l2.5 2.5L12 6' stroke='%238b85ff' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
      background-size: 12px;
      background-repeat: no-repeat;
      background-position: center;
    }

    /* ─── CTA BAND ──────────────────────────────── */
    .cta-band {
      margin: 0 auto clamp(90px, 10vw, 140px);
      width: min(92%, var(--container));
      border-radius: 18px;
      background: linear-gradient(135deg, rgba(108,99,255,0.22), rgba(108,99,255,0.06));
      border: 1px solid rgba(108,99,255,0.3);
      padding: clamp(48px, 7vw, 90px) clamp(32px, 6vw, 80px);
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 32px;
      align-items: center;
      overflow: hidden;
      position: relative;
    }

    .cta-band::before {
      content: "";
      position: absolute;
      right: -60px;
      top: -60px;
      width: 280px;
      height: 280px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(108,99,255,0.22), transparent 60%);
      pointer-events: none;
    }

    .cta-band h2 {
      font-family: 'Syne', sans-serif;
      font-size: clamp(1.8rem, 3.5vw, 3rem);
      font-weight: 800;
      color: var(--white);
      letter-spacing: -0.04em;
      line-height: 1.1;
      margin-bottom: 10px;
    }

    .cta-band p {
      font-size: 1rem;
      color: var(--muted);
    }

    .cta-actions {
      display: flex;
      gap: 12px;
      flex-shrink: 0;
    }

    /* ─── CONTACT ───────────────────────────────── */
    .contact-layout {
      display: grid;
      grid-template-columns: 0.85fr 1.15fr;
      gap: clamp(40px, 6vw, 90px);
      align-items: start;
    }

    .contact-info h2 {
      font-family: 'Syne', sans-serif;
      font-size: clamp(2.2rem, 4vw, 3.4rem);
      font-weight: 800;
      color: var(--white);
      letter-spacing: -0.04em;
      line-height: 1.05;
      margin-bottom: 20px;
    }

    .contact-details {
      border-top: 1px solid var(--line);
      margin-top: 32px;
    }

    .contact-detail-row {
      padding: 18px 0;
      border-bottom: 1px solid var(--line);
      display: flex;
      flex-direction: column;
      gap: 3px;
    }

    .contact-detail-row strong {
      font-size: 0.74rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--muted);
    }

    .contact-detail-row span {
      font-size: 0.95rem;
      color: var(--soft);
    }

    .contact-form {
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: clamp(28px, 3.5vw, 44px);
    }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: 7px;
      margin-bottom: 16px;
    }

    .form-group label {
      font-size: 0.76rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--muted);
    }

    .form-group input,
    .form-group textarea,
    .form-group select {
      width: 100%;
      padding: 13px 16px;
      background: var(--bg-2, #0e0e15);
      border: 1px solid var(--line-md);
      border-radius: 8px;
      color: var(--white);
      font-size: 0.92rem;
      transition: border-color 0.25s ease, box-shadow 0.25s ease;
    }

    .form-group input::placeholder,
    .form-group textarea::placeholder { color: #4a4a60; }

    .form-group input:focus,
    .form-group textarea:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0 3px var(--accent-glow);
    }

    .form-group textarea {
      min-height: 140px;
      resize: vertical;
    }

    /* ─── FOOTER ────────────────────────────────── */
    .site-footer {
      border-top: 1px solid var(--line);
      padding: 44px 0;
    }

    .footer-inner {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      gap: 24px;
    }

    .footer-brand {
      display: flex;
      align-items: center;
      gap: 12px;
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: 0.95rem;
    }

    .footer-brand-icon {
      width: 32px;
      height: 32px;
      border-radius: 7px;
      background: var(--accent);
      display: grid;
      place-items: center;
      font-size: 0.7rem;
      font-weight: 800;
    }

    .footer-links {
      display: flex;
      gap: 6px;
      justify-content: center;
    }

    .footer-links a {
      padding: 6px 12px;
      font-size: 0.82rem;
      color: var(--muted);
      border-radius: 5px;
      transition: color 0.2s ease, background 0.2s ease;
    }

    .footer-links a:hover {
      color: var(--white);
      background: rgba(255,255,255,0.05);
    }

    .footer-copy {
      text-align: right;
      font-size: 0.78rem;
      color: var(--muted);
    }

    /* ─── SCROLL REVEAL ─────────────────────────── */
    .reveal {
      opacity: 0;
      transform: translateY(28px);
      transition: opacity 0.75s var(--ease), transform 0.75s var(--ease);
      transition-delay: var(--d, 0s);
    }

    .reveal.in-view {
      opacity: 1;
      transform: translateY(0);
    }

    /* ─── RESPONSIVE ────────────────────────────── */
    @media (max-width: 1040px) {
      .cards-grid { grid-template-columns: 1fr 1fr; }
      .cards-grid .value-card:last-child { grid-column: 1 / -1; }
      .service-row { grid-template-columns: 1fr auto; }
      .service-row .service-num { display: none; }
      .about-grid { grid-template-columns: 1fr; }
      .about-sticky { position: relative; top: auto; }
      .cta-band { grid-template-columns: 1fr; }
      .cta-actions { flex-wrap: wrap; }
    }

    @media (max-width: 768px) {
      .split-layout { grid-template-columns: 1fr; }
      .process-grid { grid-template-columns: 1fr; }
      .pricing-grid { grid-template-columns: 1fr; }
      .contact-layout { grid-template-columns: 1fr; }
      .footer-inner { grid-template-columns: 1fr; justify-items: center; }
      .footer-copy { text-align: center; }
      .work-header { flex-direction: column; align-items: flex-start; gap: 14px; }
      .service-row { grid-template-columns: 1fr; gap: 10px; }
      .service-arrow { display: none; }
      .form-row { grid-template-columns: 1fr; }
    }

    @media (max-width: 560px) {
      .cards-grid { grid-template-columns: 1fr; }
      .cards-grid .value-card:last-child { grid-column: auto; }
      .hero-meta { gap: 20px; }
      .btn { padding: 13px 20px; font-size: 0.8rem; }
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
      }
    }
  </style>
</head>

